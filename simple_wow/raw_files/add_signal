# Tích hợp tín hiệu giao dịch vào hệ thống

import asyncio
from dataclasses import dataclass
from typing import Dict, List, Optional, Callable
from enum import Enum

class SignalType(Enum):
    BUY = "BUY"
    SELL = "SELL"
    HOLD = "HOLD"

@dataclass
class TradingSignal:
    symbol: str
    signal_type: SignalType
    price: float
    quantity: int
    confidence: float  # Độ tin cậy (0-1)
    timestamp: str
    reason: str  # Lý do tạo tín hiệu

class SignalGenerator:
    def __init__(self, api_client):
        self.api_client = api_client
        self.signals_history: List[TradingSignal] = []
    
    async def generate_signals(self) -> List[TradingSignal]:
        """
        Tạo tín hiệu giao dịch dựa trên các chỉ báo kỹ thuật
        """
        signals = []
        symbols = ["VNM", "VCB", "TCB", "HPG"]
        for symbol in symbols:
            signal = await self._check_rsi_signal(symbol)
            if signal:
                signals.append(signal)
        return signals
    
    async def _check_rsi_signal(self, symbol: str) -> Optional[TradingSignal]:
        """
        Kiểm tra tín hiệu dựa trên RSI
        """
        try:
            current_price = await self._get_current_price(symbol)
            rsi_value = await self._calculate_rsi(symbol)
            if rsi_value > 70:
                return TradingSignal(
                    symbol=symbol,
                    signal_type=SignalType.SELL,
                    price=current_price,
                    quantity=100,
                    confidence=0.8,
                    timestamp=self._get_current_time(),
                    reason=f"RSI quá mua: {rsi_value}"
                )
            elif rsi_value < 30:
                return TradingSignal(
                    symbol=symbol,
                    signal_type=SignalType.BUY,
                    price=current_price,
                    quantity=100,
                    confidence=0.8,
                    timestamp=self._get_current_time(),
                    reason=f"RSI quá bán: {rsi_value}"
                )
        except Exception as e:
            print(f"Lỗi khi kiểm tra tín hiệu cho {symbol}: {e}")
        return None
    
