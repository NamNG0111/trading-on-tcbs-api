# TCBS API Credentials Configuration
# Copy this file to credentials.yaml and fill in your actual values
# NEVER commit credentials.yaml to version control

tcbs_api:
  api_key: "your-api-key-here"
  custody_code: "your-custody-code"
  account_id: "your-account-id"
  sub_account_id: "your-sub-account-id"
  base_url: "https://openapi.tcbs.com.vn"

# Optional: Environment-specific settings
environment: "production"  # or "sandbox", "development"

# Security settings
security:
  token_file: "config/token.json"
  token_refresh_interval: 3600  # seconds
  max_retry_attempts: 3
  request_timeout: 30  # seconds
